# Production environment template for EC2
# Copy to .env on the server:  cp deploy/env.production.example .env

# MongoDB Atlas (required) — add EC2 Elastic IP to Atlas Network Access
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/kids_assessment?retryWrites=true&w=majority"

# Auth (required) — NEXTAUTH_URL must match your public URL (domain or EC2 DNS)
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_URL="https://YOUR_DOMAIN"
NEXTAUTH_TRUST_HOST="true"

# AI analysis
GEMINI_API_KEY=""

# AWS S3 video storage (use IAM role on EC2 if possible, or access keys)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
